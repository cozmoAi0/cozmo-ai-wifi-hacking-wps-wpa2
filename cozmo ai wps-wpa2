# ====================== SETUP MONITOR MODE ======================
def setup_monitor_mode():
    """تشغيل وضع المراقبة"""
    print(f"\n{Colors.YELLOW}[1] Setting up monitor mode...{Colors.END}")
    
    subprocess.run("sudo airmon-ng check kill", shell=True, capture_output=True)
    time.sleep(1)
    
    result = subprocess.run("iwconfig 2>/dev/null | grep -o '^[^ ]*' | head -1", 
                           shell=True, capture_output=True, text=True)
    iface = result.stdout.strip()
    
    if not iface or iface == 'lo':
        print(f"{Colors.RED}[-] No wireless interface found!{Colors.END}")
        return None
    
    print(f"{Colors.GREEN}[+] Interface: {iface}{Colors.END}")
    subprocess.run(f"sudo airmon-ng start {iface}", shell=True, capture_output=True)
    time.sleep(2)
    
    mon_iface = f"{iface}mon"
    result = subprocess.run(f"iwconfig {mon_iface} 2>/dev/null | grep -i monitor", 
                           shell=True, capture_output=True)
    
    if result.returncode != 0:
        mon_iface = iface
    
    print(f"{Colors.GREEN}[+] Monitor mode ready: {mon_iface}{Colors.END}")
    return mon_iface

